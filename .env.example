# =============================================
# FIREBASE - Service Account (Backend)
# =============================================
# Necesario para Netlify Functions
# Generar en: Firebase Console > Configuración del proyecto > Cuentas de servicio
# IMPORTANTE: Pegar el JSON completo en una sola línea

FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"ondelivery-0243","private_key":"...","client_email":"..."}

