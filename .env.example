# =============================================
# ON Delivery - Variables de Entorno
# =============================================
# Copia este archivo como .env.local y completa los valores
# NUNCA subas .env.local a GitHub (ya está en .gitignore)

# =============================================
# FIREBASE - Configuración Frontend
# =============================================
# Obtén estos valores en: Firebase Console > Configuración del proyecto > Tus aplicaciones

VITE_FIREBASE_API_KEY=AIzaSyBvnHxA7wSYDkZnpzHXIMUxCas8872jheU
VITE_FIREBASE_AUTH_DOMAIN=ondelivery-0243.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=ondelivery-0243
VITE_FIREBASE_STORAGE_BUCKET=ondelivery-0243.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=49907880119
VITE_FIREBASE_APP_ID=1:49907880119:web:b72302b9a7eadc2113bd32

